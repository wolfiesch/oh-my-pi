{
  "name": "@oh-my-pi/app-wire",
  "version": "0.6.2",
  "type": "module",
  "description": "Compatibility name for the T4-owned host wire contract",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "bun run check:types",
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit && tsgo -p tsconfig.strict.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test test/*.test.ts",
    "typecheck:strict": "tsgo -p tsconfig.strict.json --noEmit",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": { "@t4-code/host-wire": "0.1.30" },
  "engines": { "bun": ">=1.3.14" }
}
