{
  "name": "@oh-my-pi/app-wire",
  "version": "0.5.7",
  "type": "module",
  "description": "Dependency-free omp app protocol frames and bounded decoders",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "files": ["src", "fixtures/v1", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "bun run check:types",
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit && tsgo -p tsconfig.strict.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test test/*.test.ts",
    "typecheck:strict": "tsgo -p tsconfig.strict.json --noEmit",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "engines": { "bun": ">=1.3.14" }
}
