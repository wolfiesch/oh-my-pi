{
  "name": "@oh-my-pi/app-wire",
  "version": "0.5.4",
  "private": true,
  "type": "module",
  "description": "Dependency-free omp app protocol frames and bounded decoders",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "files": ["src", "fixtures/v1", "README.md", "LICENSE"],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test test/*.test.ts",
    "typecheck:strict": "bunx tsc -p tsconfig.strict.json --noEmit"
  },
  "engines": { "bun": ">=1.3.14" }
}
